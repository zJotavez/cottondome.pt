# Cotton Dome LDA — Variáveis de Ambiente
# Copie este ficheiro para .env e preencha com os seus valores

# ─────────────────────────────────────
# SUPABASE (obrigatório para o painel funcionar)
# Encontre estes valores em: Supabase Dashboard → Project Settings → API
# ─────────────────────────────────────
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# ─────────────────────────────────────
# URL do Site (opcional)
# ─────────────────────────────────────
VITE_APP_URL=https://domme.pt
