{
  "version": 2,
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "/images/$1"
    },
    {
      "source": "/videos/(.*)",
      "destination": "/videos/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
